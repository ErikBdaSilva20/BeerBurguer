# =========================
# SERVIDOR
# =========================
PORT=3001

# =========================
# BANCO DE DADOS - PostgreSQL
# =========================
# Produção: cole aqui a "Internal Database URL" do Render
# Desenvolvimento local: deixe em branco e configure DB_HOST, DB_USER, etc. abaixo
DATABASE_URL=

# Variáveis locais (usadas quando DATABASE_URL estiver vazio)
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=123456
DB_NAME=dev-burguer-api

# =========================
# BANCO DE DADOS - MongoDB
# =========================
MONGO_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# =========================
# MERCADO PAGO
# =========================
# Produção: use o Access Token de PRODUÇÃO do painel Mercado Pago Developers
# Desenvolvimento: use o Access Token de TESTE (começa com TEST-...)
MERCADOPAGO_ACCESS_TOKEN=

# =========================
# FIREBASE ADMIN (SDK do servidor - NÃO é o SDK do cliente)
# =========================
# Aponta para o arquivo serviceAccountKey.json (nunca commite esse arquivo!)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# =========================
# URLs (OBRIGATÓRIO para os redirects do Mercado Pago funcionarem)
# =========================
# Desenvolvimento
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Produção (descomente e preencha ao fazer deploy)
# APP_URL=https://api-devburguer.onrender.com
# FRONTEND_URL=https://devburguer.vercel.app
