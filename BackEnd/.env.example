# =========================
# SERVIDOR
# =========================
PORT=3001

# =========================
# BANCO DE DADOS - PostgreSQL
# =========================
# DESENVOLVIMENTO: URL completa do banco local
DATABASE_URL=postgresql://admin:123456@localhost:5432/dev-burguer-api

# PRODUÇÃO (Render): Cole aqui a "Internal Database URL" do painel do Render
# Formato: postgresql://<user>:<password>@<host>/<dbname>
# DATABASE_URL=postgresql://<user>:<password>@<host>.render.com/<dbname>

# Variáveis locais (fallback para desenvolvimento se DATABASE_URL estiver vazio)
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=123456
DB_NAME=dev-burguer-api

# =========================
# BANCO DE DADOS - MongoDB
# =========================
MONGO_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# =========================
# ASAAS PAGAMENTOS
# =========================
# Desenvolvimento: Sandbox Asaas (começa com $aact_...)
# Produção: Produção Asaas (começa com $aact_...)
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3


# =========================
# FIREBASE ADMIN (SDK do servidor - NÃO é o SDK do cliente)
# =========================
# Aponta para o arquivo serviceAccountKey.json (NUNCA commite esse arquivo!)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# =========================
# URLs (OBRIGATÓRIO para os redirects do Asaas funcionarem)
# =========================
# DESENVOLVIMENTO
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# PRODUÇÃO (descomente e preencha ao fazer deploy)
# APP_URL=https://api-devburguer.onrender.com
# FRONTEND_URL=https://devburguer.vercel.app

# =========================
# CLOUDINARY (Uploads de Imagens)
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
