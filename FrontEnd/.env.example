# =========================
# URL DA API BACKEND
# =========================
# Desenvolvimento: aponta para o servidor local
VITE_API_URL=http://localhost:3001
# Produção (descomente ao fazer deploy na Vercel):
# VITE_API_URL=https://api-devburguer.onrender.com

# =========================
# PAGAMENTO ASAAS
# =========================
# O Asaas não exige chaves públicas configuradas no frontend.
# As chaves de API ficam apenas no .env do BackEnd por segurança.


# =========================
# FIREBASE (configurações do app cliente)
# =========================
# Encontre esses valores em: Firebase Console > Configurações do projeto > Seus apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
