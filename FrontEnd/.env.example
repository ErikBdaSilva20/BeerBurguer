# =========================
# URL DA API BACKEND
# =========================
# Desenvolvimento: aponta para o servidor local
VITE_API_URL=http://localhost:3001
# Produção (descomente ao fazer deploy na Vercel):
# VITE_API_URL=https://api-devburguer.onrender.com

# =========================
# MERCADO PAGO (chave pública do cliente)
# =========================
# Produção: use a Public Key de PRODUÇÃO
# Desenvolvimento: use a Public Key de TESTE (começa com TEST-...)
VITE_MERCADOPAGO_PUBLIC_KEY=

# =========================
# FIREBASE (configurações do app cliente)
# =========================
# Encontre esses valores em: Firebase Console > Configurações do projeto > Seus apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
